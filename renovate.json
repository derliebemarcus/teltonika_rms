{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>derliebemarcus/maintenance:python"
  ],
  "packageRules": [
    {
      "description": "Keep python-socketio runtime and test pins together",
      "matchPackageNames": [
        "python-socketio"
      ],
      "groupName": "python-socketio runtime dependency",
      "semanticCommitType": "fix",
      "semanticCommitScope": "deps",
      "automerge": true,
      "automergeType": "pr"
    }
  ],
  "constraints": {
    "python": "==3.14"
  },
  "pip-compile": {
    "managerFilePatterns": [
      "/(^|/)requirements\\.txt$/"
    ]
  },
  "pip_requirements": {
    "enabled": false
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": [
      "before 06:00 on monday"
    ],
    "branchTopic": "home-assistant-lockfile-refresh",
    "commitMessageAction": "refresh",
    "commitMessageTopic": "Home Assistant dependency lockfile"
  }
}
