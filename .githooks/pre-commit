#!/usr/bin/env bash
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
REPORT_FILE="$(mktemp "${TMPDIR:-/tmp}/teltonika-rms-pytest-XXXXXX.xml")"
VENV_DIR="$ROOT/.venv-test"
COVERAGE_MINIMUM="98.50"

pick_bootstrap_python() {
  if command -v python3.14 >/dev/null 2>&1; then
    echo "python3.14"
    return
  fi
  if command -v python3.13 >/dev/null 2>&1; then
    echo "python3.13"
    return
  fi
  if command -v python3 >/dev/null 2>&1; then
    echo "python3"
    return
  fi
  if command -v python >/dev/null 2>&1; then
    echo "python"
    return
  fi
  echo "[pre-commit] No Python interpreter found (python3.13/python3/python)." >&2
  exit 1
}

BOOTSTRAP_PYTHON="$(pick_bootstrap_python)"

if [ ! -x "$VENV_DIR/bin/python" ]; then
  echo "[pre-commit] Creating local test environment at $VENV_DIR using $BOOTSTRAP_PYTHON."
  "$BOOTSTRAP_PYTHON" -m venv "$VENV_DIR"
fi

PYTHON_BIN="$VENV_DIR/bin/python"

module_exists() {
  local module="$1"
  "$PYTHON_BIN" -c "import importlib.util, sys; sys.exit(0 if importlib.util.find_spec('$module') else 1)"
}

ensure_package() {
  local module="$1"
  shift
  if module_exists "$module"; then
    return
  fi
  echo "[pre-commit] Installing missing dependency for '$module': $*"
  "$PYTHON_BIN" -m pip install --disable-pip-version-check "$@"
  if ! module_exists "$module"; then
    echo "[pre-commit] Dependency '$module' is still unavailable after installation." >&2
    exit 1
  fi
}

cleanup() {
  rm -f "$REPORT_FILE"
}
trap cleanup EXIT

cd "$ROOT" || exit 1

ensure_package "pytest" "pytest>=8,<10"
ensure_package "pytest_cov" "pytest-cov>=6,<7"
ensure_package "socketio" "python-socketio==5.11.2"
ensure_package "ruff" "ruff"
ensure_package "mypy" "mypy>=1.15"
ensure_package "pytest_asyncio" "pytest-asyncio<0.24,>=0.23"
ensure_package "pip_audit" "pip-audit"
ensure_package "piptools" "pip-tools"
ensure_package "pydantic" "pydantic>=2.0"
ensure_package "syrupy" "syrupy>=4.0"
ensure_package "flake8" "flake8>=7.0"
ensure_package "pylint" "pylint>=3.0"
ensure_package "bandit" "bandit>=1.7"

HAS_HA_TESTS=0
if [ -d "$ROOT/tests/ha" ]; then
  HAS_HA_TESTS=1
  ensure_package "homeassistant" "homeassistant>=2025.1.0"
fi

echo "[pre-commit] Checking lockfile consistency..."
cp requirements.txt /tmp/requirements.txt.tmp

if ! "$PYTHON_BIN" -m piptools compile \
  --no-strip-extras \
  --no-header \
  requirements-dev.txt \
  -o /tmp/requirements.txt.tmp >/dev/null 2>&1; then
  echo "[pre-commit] Failed to compile requirements-dev.txt."
  exit 1
fi

if ! diff requirements.txt /tmp/requirements.txt.tmp >/dev/null 2>&1; then
  echo "[pre-commit] lockfile (requirements.txt) is out of sync with requirements-dev.txt."
  echo "[pre-commit] Run 'make lock' to update."
  exit 1
fi

echo "[pre-commit] Running ruff auto-fixes..."
"$PYTHON_BIN" -m ruff format .
"$PYTHON_BIN" -m ruff check . --fix

echo "[pre-commit] Running ruff format check..."
if ! "$PYTHON_BIN" -m ruff format --check .; then
  echo "[pre-commit] Code formatting failed. Run 'ruff format .' to fix."
  exit 1
fi

echo "[pre-commit] Running ruff lint check..."
if ! "$PYTHON_BIN" -m ruff check .; then
  echo "[pre-commit] Linting failed. Run 'ruff check --fix .' to fix."
  exit 1
fi

echo "[pre-commit] Running mypy type check..."
if ! "$PYTHON_BIN" -m mypy .; then
  echo "[pre-commit] Type checking failed. Fix mypy errors before committing."
  exit 1
fi

echo "[pre-commit] Checking translation consistency..."
if ! "$PYTHON_BIN" tools/check_translations.py; then
  echo "[pre-commit] Translation check failed."
  exit 1
fi

echo "[pre-commit] Checking release notes format..."
if ! "$PYTHON_BIN" tools/check_release_notes.py custom_components/teltonika_rms/manifest.json CHANGELOG.md; then
  echo "[pre-commit] Release notes check failed."
  exit 1
fi

echo "[pre-commit] Running pip-audit security check..."
if ! "$PYTHON_BIN" -m pip_audit -r requirements-dev.txt --ignore-vuln CVE-2025-67221 --ignore-vuln CVE-2026-32597 --ignore-vuln CVE-2026-27448 --ignore-vuln CVE-2026-27459 --ignore-vuln CVE-2026-4539 --ignore-vuln CVE-2026-25645 --ignore-vuln CVE-2026-34073 --ignore-vuln CVE-2026-39892 --ignore-vuln GHSA-pjjw-68hj-v9mw --ignore-vuln CVE-2025-71176 --ignore-vuln CVE-2026-34993 --ignore-vuln CVE-2026-47265 --ignore-vuln CVE-2026-54273 --ignore-vuln CVE-2026-54279 --ignore-vuln CVE-2026-54277 --ignore-vuln CVE-2026-50269 --ignore-vuln CVE-2026-54276 --ignore-vuln CVE-2026-54278 --ignore-vuln CVE-2026-54280 --ignore-vuln CVE-2026-54274 --ignore-vuln CVE-2026-54275 --ignore-vuln GHSA-537c-gmf6-5ccf --ignore-vuln PYSEC-2026-175 --ignore-vuln PYSEC-2026-176 --ignore-vuln PYSEC-2026-177 --ignore-vuln PYSEC-2026-178 --ignore-vuln PYSEC-2026-179 ; then
  echo "[pre-commit] Security audit failed. Fix vulnerable dependencies before committing."
  exit 1
fi

TEST_TARGETS=("tests/unit")
if [ "$HAS_HA_TESTS" -eq 1 ]; then
  TEST_TARGETS+=("tests/ha")
  echo "[pre-commit] Running test suite: unit + HA."
else
  echo "[pre-commit] Running test suite: unit only."
fi

"$PYTHON_BIN" -m pytest --maxfail=0 "${TEST_TARGETS[@]}" \
  --cov=. \
  --cov-config=.coveragerc \
  --cov-report=xml:coverage.xml \
  --cov-report=term \
  --junitxml "$REPORT_FILE"
PYTEST_EXIT=$?

if [ "$PYTEST_EXIT" -eq 0 ]; then
  "$PYTHON_BIN" "$ROOT/tools/check_coverage_threshold.py" "$ROOT/coverage.xml" "$COVERAGE_MINIMUM"
  PYTEST_EXIT=$?
fi

"$PYTHON_BIN" tools/print_pytest_summary.py "$REPORT_FILE"

if [ "$PYTEST_EXIT" -ne 0 ]; then
  echo "[pre-commit] Commit blocked: at least one test failed."
  exit 1
fi

echo "[pre-commit] Generating analysis reports for SonarQube..."
"$PYTHON_BIN" -m ruff check . --output-format json --output-file ruff-report.json --exclude .venv-test --exclude .venv || true
"$PYTHON_BIN" -m mypy . --exclude .venv-test --exclude .venv > mypy-report.txt || true
"$PYTHON_BIN" -m flake8 . --exit-zero --exclude .venv-test,.venv > flake8-report.txt
"$PYTHON_BIN" -m pylint custom_components/teltonika_rms --exit-zero > pylint-report.txt
"$PYTHON_BIN" -m bandit -r custom_components/teltonika_rms -f json -o bandit-report.json --exit-zero

echo "[pre-commit] Running SonarQube Analysis..."

# Ensure common paths are included (especially for sonar-scanner)
export PATH="$PATH:/usr/local/bin:/opt/homebrew/bin"

# Load SONAR_TOKEN from common locations if not already set
if [ -z "${SONAR_TOKEN:-}" ]; then
  if [ -f "$ROOT/.env" ]; then
    set -a; source "$ROOT/.env"; set +a
  fi
fi
if [ -z "${SONAR_TOKEN:-}" ]; then
  if [ -f "$HOME/.aliases" ]; then
    # shellcheck disable=SC1090
    source "$HOME/.aliases"
  fi
fi

if [ -z "${SONAR_TOKEN:-}" ]; then
  echo "[pre-commit] Error: SONAR_TOKEN is not set. Cannot run SonarQube analysis."
  exit 1
fi

# Run scanner and wait for quality gate result
if ! sonar-scanner \
  -Dsonar.projectKey=teltonika_rms \
  -Dsonar.host.url=https://sonarqube.home.siczb.de \
  -Dsonar.token="$SONAR_TOKEN" \
  -Dsonar.qualitygate.wait=true \
  -Dsonar.python.version=3.14 \
  -Dsonar.sources=custom_components/teltonika_rms \
  -Dsonar.tests=tests \
  -Dsonar.python.coverage.reportPaths=coverage.xml \
  -Dsonar.python.flake8.reportPaths=flake8-report.txt \
  -Dsonar.python.mypy.reportPaths=mypy-report.txt \
  -Dsonar.python.pylint.reportPaths=pylint-report.txt \
  -Dsonar.python.ruff.reportPaths=ruff-report.json \
  -Dsonar.python.bandit.reportPaths=bandit-report.json; then
  echo "[pre-commit] SonarQube Quality Gate FAILED. Commit blocked."
  exit 1
fi

echo "[pre-commit] SonarQube Quality Gate passed."
echo "[pre-commit] All tests passed."
exit 0
