#!/usr/bin/env bash
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
REPORT_FILE="$(mktemp "${TMPDIR:-/tmp}/teltonika-rms-pytest-XXXXXX.xml")"
VENV_DIR="$ROOT/.venv-test"
COVERAGE_MINIMUM="97.1"

pick_bootstrap_python() {
  if command -v python3.13 >/dev/null 2>&1; then
    echo "python3.13"
    return
  fi
  if command -v python3 >/dev/null 2>&1; then
    echo "python3"
    return
  fi
  if command -v python >/dev/null 2>&1; then
    echo "python"
    return
  fi
  echo "[pre-commit] No Python interpreter found (python3.13/python3/python)." >&2
  exit 1
}

BOOTSTRAP_PYTHON="$(pick_bootstrap_python)"

if [ ! -x "$VENV_DIR/bin/python" ]; then
  echo "[pre-commit] Creating local test environment at $VENV_DIR using $BOOTSTRAP_PYTHON."
  "$BOOTSTRAP_PYTHON" -m venv "$VENV_DIR"
fi

PYTHON_BIN="$VENV_DIR/bin/python"

module_exists() {
  local module="$1"
  "$PYTHON_BIN" -c "import importlib.util, sys; sys.exit(0 if importlib.util.find_spec('$module') else 1)"
}

ensure_package() {
  local module="$1"
  shift
  if module_exists "$module"; then
    return
  fi
  echo "[pre-commit] Installing missing dependency for '$module': $*"
  "$PYTHON_BIN" -m pip install --disable-pip-version-check "$@"
  if ! module_exists "$module"; then
    echo "[pre-commit] Dependency '$module' is still unavailable after installation." >&2
    exit 1
  fi
}

cleanup() {
  rm -f "$REPORT_FILE"
}
trap cleanup EXIT

cd "$ROOT" || exit 1

ensure_package "pytest" "pytest>=8,<10"
ensure_package "pytest_cov" "pytest-cov>=6,<7"
ensure_package "socketio" "python-socketio==5.11.2"

HAS_HA_TESTS=0
if [ -d "$ROOT/tests/ha" ]; then
  HAS_HA_TESTS=1
  ensure_package "homeassistant" "homeassistant>=2025.1.0"
fi

TEST_TARGETS=("tests/unit")
if [ "$HAS_HA_TESTS" -eq 1 ]; then
  TEST_TARGETS+=("tests/ha")
  echo "[pre-commit] Running test suite: unit + HA."
else
  echo "[pre-commit] Running test suite: unit only."
fi

"$PYTHON_BIN" -m pytest --maxfail=0 "${TEST_TARGETS[@]}" \
  --cov=. \
  --cov-config=.coveragerc \
  --cov-report=xml:coverage.xml \
  --cov-report=term \
  --junitxml "$REPORT_FILE"
PYTEST_EXIT=$?

if [ "$PYTEST_EXIT" -eq 0 ]; then
  "$PYTHON_BIN" "$ROOT/tools/check_coverage_threshold.py" "$ROOT/coverage.xml" "$COVERAGE_MINIMUM"
  PYTEST_EXIT=$?
fi

"$PYTHON_BIN" tools/print_pytest_summary.py "$REPORT_FILE"

if [ "$PYTEST_EXIT" -ne 0 ]; then
  echo "[pre-commit] Commit blocked: at least one test failed."
  exit 1
fi

echo "[pre-commit] All tests passed."
exit 0
